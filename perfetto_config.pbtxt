buffers: {
  size_kb: 40960
  fill_policy: RING_BUFFER
}

data_sources: {
  config {
    name: "linux.perf"
    target_buffer: 0

    perf_event_config {
      timebase {
        frequency: 1000
      }

      callstack_sampling {
        scope {
          target_cmdline: "Debugger"   # ⚠️ 关键
        }

        kernel_frames: false   # native分析一般关掉更清晰
      }
    }
  }
}

duration_ms: 10000